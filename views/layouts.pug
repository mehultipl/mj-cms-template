extends layout

block content
    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Layouts
        a.btn.btn-primary(href="/layouts/new")
            span.material-icons.me-1 add
            | New Layout

    .card.border-0.shadow-sm
        .card-body
            table.table.table-hover#layoutsTable
                thead
                    tr
                        th Name
                        th Description
                        th Updated
                        th Actions
                tbody
                    tr
                        td(colspan="4").text-center Loading...

block scripts
    script.
        async function loadLayouts() {
            try {
                const response = await fetch('/api/layouts');
                const layouts = await response.json();

                const tbody = document.querySelector('#layoutsTable tbody');

                if (layouts.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No layouts found. Create your first layout!</td></tr>';
                    return;
                }

                tbody.innerHTML = layouts.map(layout => `
                    <tr>
                        <td><strong>${layout.name || 'Untitled'}</strong></td>
                        <td>${layout.description || '-'}</td>
                        <td>${new Date(layout.updatedAt).toLocaleDateString()}</td>
                        <td>
                            <a href="/layouts/${layout.id}" class="btn btn-sm btn-outline-primary">
                                <span class="material-icons" style="font-size: 16px">edit</span>
                            </a>
                            <button onclick="deleteLayout('${layout.id}')" class="btn btn-sm btn-outline-danger">
                                <span class="material-icons" style="font-size: 16px">delete</span>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading layouts:', error);
            }
        }

        async function deleteLayout(id) {
            if (!confirm('Are you sure you want to delete this layout?')) return;
            try {
                await fetch(`/api/layouts/${id}`, { method: 'DELETE' });
                loadLayouts();
            } catch (error) {
                alert('Error deleting layout');
            }
        }

        loadLayouts();
