doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport" content="width=device-width, initial-scale=1.0")
        title= `${title || 'CMS'} - ${site.name}`
        link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet")
        link(href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet")
        link(href="https://cdn.jsdelivr.net/npm/codemirror@5.65.2/lib/codemirror.min.css" rel="stylesheet")
        style.
            .sidebar {
                min-height: 100vh;
                background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            }
            .sidebar .nav-link {
                color: rgba(255, 255, 255, 0.8);
                border-radius: 8px;
                margin: 2px 0;
            }
            .sidebar .nav-link:hover,
            .sidebar .nav-link.active {
                color: white;
                background: rgba(255, 255, 255, 0.1);
            }
            .main-content {
                background: #f8f9fa;
                min-height: 100vh;
            }
            .CodeMirror {
                height: 300px;
                border: 1px solid #ddd;
                border-radius: 4px;
            }
        block styles
    body
        .container-fluid
            .row
                //- Sidebar
                nav.col-md-3.col-lg-2.sidebar.p-3
                    .d-flex.align-items-center.mb-4
                        span.material-icons.text-white.me-2 language
                        h5.text-white.mb-0= site.name

                    ul.nav.flex-column
                        li.nav-item
                            a.nav-link(href="/" class=(active === 'dashboard' ? 'active' : ''))
                                span.material-icons.me-2 dashboard
                                | Dashboard
                        li.nav-item
                            a.nav-link(href="/pages" class=(active === 'pages' ? 'active' : ''))
                                span.material-icons.me-2 article
                                | Pages
                        li.nav-item
                            a.nav-link(href="/layouts" class=(active === 'layouts' ? 'active' : ''))
                                span.material-icons.me-2 view_quilt
                                | Layouts
                        li.nav-item
                            a.nav-link(href="/components" class=(active === 'components' ? 'active' : ''))
                                span.material-icons.me-2 widgets
                                | Components
                        li.nav-item
                            a.nav-link(href="/media" class=(active === 'media' ? 'active' : ''))
                                span.material-icons.me-2 perm_media
                                | Media
                        li.nav-item
                            a.nav-link(href="/collections" class=(active === 'collections' ? 'active' : ''))
                                span.material-icons.me-2 inventory_2
                                | Collections
                        li.nav-item.mt-4
                            a.nav-link(href="/build" class=(active === 'build' ? 'active' : ''))
                                span.material-icons.me-2 build
                                | Build Site

                //- Main Content
                main.col-md-9.col-lg-10.main-content.p-4
                    block content

        script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
        script(src="https://cdn.jsdelivr.net/npm/codemirror@5.65.2/lib/codemirror.min.js")
        script(src="https://cdn.jsdelivr.net/npm/codemirror@5.65.2/mode/htmlmixed/htmlmixed.min.js")
        script(src="https://cdn.jsdelivr.net/npm/codemirror@5.65.2/mode/css/css.min.js")
        script(src="https://cdn.jsdelivr.net/npm/codemirror@5.65.2/mode/javascript/javascript.min.js")
        block scripts
