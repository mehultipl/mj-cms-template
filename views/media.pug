extends layout

block content
    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Media Library
        label.btn.btn-primary
            span.material-icons.me-1 upload
            | Upload Files
            input#fileInput(type="file" multiple hidden onchange="uploadFiles(this.files)")

    .card.border-0.shadow-sm
        .card-body
            #uploadProgress.mb-3(style="display: none")
                .progress
                    .progress-bar.progress-bar-striped.progress-bar-animated(style="width: 0%")

            .row#mediaGrid
                .col-12.text-center
                    p.text-muted Loading media...

block scripts
    script.
        async function loadMedia() {
            try {
                const response = await fetch('/api/media');
                const media = await response.json();
                const grid = document.getElementById('mediaGrid');

                if (!media || media.length === 0) {
                    grid.innerHTML = '<div class="col-12 text-center"><p class="text-muted">No media files. Upload your first file!</p></div>';
                    return;
                }

                grid.innerHTML = media.map(item => `
                    <div class="col-md-2 col-sm-3 mb-3">
                        <div class="card h-100">
                            <img src="${item.url || '/uploads/' + item.filename}" class="card-img-top" style="height: 120px; object-fit: cover;" alt="${item.originalName || item.filename}">
                            <div class="card-body p-2">
                                <small class="text-truncate d-block">${item.originalName || item.filename}</small>
                            </div>
                            <div class="card-footer p-1 bg-white">
                                <button onclick="copyUrl('${item.url || '/uploads/' + item.filename}')" class="btn btn-sm btn-outline-secondary" title="Copy URL">
                                    <span class="material-icons" style="font-size: 14px">content_copy</span>
                                </button>
                                <button onclick="deleteMedia('${item.id || item._id}')" class="btn btn-sm btn-outline-danger" title="Delete">
                                    <span class="material-icons" style="font-size: 14px">delete</span>
                                </button>
                            </div>
                        </div>
                    </div>
                `).join('');
            } catch (error) {
                console.error('Error:', error);
                document.getElementById('mediaGrid').innerHTML = '<div class="col-12 text-center text-danger">Error loading media</div>';
            }
        }

        async function uploadFiles(files) {
            const progress = document.getElementById('uploadProgress');
            const bar = progress.querySelector('.progress-bar');
            progress.style.display = 'block';

            for (let i = 0; i < files.length; i++) {
                const formData = new FormData();
                formData.append('file', files[i]);

                bar.style.width = `${((i + 1) / files.length) * 100}%`;

                try {
                    await fetch('/api/media/upload', {
                        method: 'POST',
                        body: formData
                    });
                } catch (error) {
                    console.error('Upload error:', error);
                }
            }

            progress.style.display = 'none';
            loadMedia();
        }

        function copyUrl(url) {
            navigator.clipboard.writeText(window.location.origin + url);
            alert('URL copied!');
        }

        async function deleteMedia(id) {
            if (!confirm('Delete this file?')) return;
            try {
                await fetch(`/api/media/${id}`, { method: 'DELETE' });
                loadMedia();
            } catch (error) {
                alert('Error deleting');
            }
        }

        loadMedia();
