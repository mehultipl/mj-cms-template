extends layout

block content
    .d-flex.justify-content-between.align-items-center.mb-4
        h2 Pages
        a.btn.btn-primary(href="/pages/new")
            span.material-icons.me-1 add
            | New Page

    .card.border-0.shadow-sm
        .card-body
            table.table.table-hover#pagesTable
                thead
                    tr
                        th Title
                        th Slug
                        th Layout
                        th Status
                        th Updated
                        th Actions
                tbody
                    tr
                        td(colspan="6").text-center Loading...

block scripts
    script.
        async function loadPages() {
            try {
                const response = await fetch('/api/pages');
                const pages = await response.json();

                const tbody = document.querySelector('#pagesTable tbody');

                if (pages.length === 0) {
                    tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No pages found. Create your first page!</td></tr>';
                    return;
                }

                tbody.innerHTML = pages.map(page => `
                    <tr>
                        <td><strong>${page.title || page.name || 'Untitled'}</strong></td>
                        <td><code>/${page.slug || ''}</code></td>
                        <td>${page.layout || 'default'}</td>
                        <td><span class="badge bg-${page.status === 'published' ? 'success' : 'warning'}">${page.status || 'draft'}</span></td>
                        <td>${new Date(page.updatedAt).toLocaleDateString()}</td>
                        <td>
                            <a href="/pages/${page.id}" class="btn btn-sm btn-outline-primary">
                                <span class="material-icons" style="font-size: 16px">edit</span>
                            </a>
                            <button onclick="deletePage('${page.id}')" class="btn btn-sm btn-outline-danger">
                                <span class="material-icons" style="font-size: 16px">delete</span>
                            </button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                console.error('Error loading pages:', error);
                document.querySelector('#pagesTable tbody').innerHTML =
                    '<tr><td colspan="6" class="text-center text-danger">Error loading pages</td></tr>';
            }
        }

        async function deletePage(id) {
            if (!confirm('Are you sure you want to delete this page?')) return;

            try {
                await fetch(`/api/pages/${id}`, { method: 'DELETE' });
                loadPages();
            } catch (error) {
                alert('Error deleting page');
            }
        }

        loadPages();
